{
  "name": "capacitor-sqlite-demo-react",
  "version": "0.0.1",
  "author": "Capawesome Team",
  "homepage": "https://capawesome.io/",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run copy:sqlite-wasm",
    "start": "npm run copy:sqlite-wasm && vite",
    "dev": "npm run copy:sqlite-wasm && vite",
    "ionic:serve": "npm run copy:sqlite-wasm && vite",
    "ionic:build": "npm run copy:sqlite-wasm && tsc -b && vite build",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "copy:sqlite-wasm": "node ./scripts/copy-sqlite-wasm.mjs",
    "postinstall": "npm run copy:sqlite-wasm"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome-team/capacitor-sqlite": "^0.3.6",
    "@ionic/react": "^8.8.4",
    "@ionic/react-router": "^8.8.4",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build9",
    "ionicons": "^8.0.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sass": "^1.99.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "description": "A demo app for the Capawesome SQLite plugin"
